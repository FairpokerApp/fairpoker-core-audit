GENERATE_SOURCEMAP=false
REACT_APP_SIGNALING_URL=https://fairpoker-signal.fair-poker-relay.workers.dev

# RELEASE BOUNDARY:
# This is the already-published playable table client CID for release scripts.
# It intentionally does not use a REACT_APP_* name; CRA embeds every REACT_APP_*
# value into the browser bundle. Homepage/static evidence must read ai.json at
# runtime, while the IPFS game client CID is updated only by npm run release:all.
