    </footer>

    <script>
      (function(){
        var KEY='fairpoker:language';
        var avail=['zh','en'];
        function has(l){return avail.indexOf(l)>=0}
        var cur=null;try{cur=localStorage.getItem(KEY)}catch(e){}
        if(!cur||!has(cur)) cur='zh';
        document.documentElement.setAttribute('data-lang',cur);
        var bar=document.getElementById('fp-langs');
        if(bar){
          var btns=bar.querySelectorAll('button');
          Array.prototype.forEach.call(btns,function(b){
            var l=b.getAttribute('data-set');
            b.setAttribute('aria-pressed', l===cur?'true':'false');
            b.addEventListener('click',function(){
              document.documentElement.setAttribute('data-lang',l);
              try{localStorage.setItem(KEY,l)}catch(e){}
              Array.prototype.forEach.call(btns,function(x){x.setAttribute('aria-pressed', x.getAttribute('data-set')===l?'true':'false')});
              document.dispatchEvent(new Event('fairpoker:languagechange'));
            });
          });
        }
      })();

      (function(){
        var languages=['zh','en','ja','es','fr','de'];
        var labels={
          zh:{active:'已公开',continuous:'持续扫描',planned:'计划中','needs-review':'需复核',unavailable:'不可用'},
          en:{active:'Published',continuous:'Continuous',planned:'Planned','needs-review':'Needs review',unavailable:'Unavailable'},
          ja:{active:'公開済み',continuous:'継続中',planned:'予定','needs-review':'要確認',unavailable:'利用不可'},
          es:{active:'Publicado',continuous:'Continuo',planned:'Planificado','needs-review':'Revisar',unavailable:'No disponible'},
          fr:{active:'Publié',continuous:'Continu',planned:'Prévu','needs-review':'À vérifier',unavailable:'Indisponible'},
          de:{active:'Veröffentlicht',continuous:'Laufend',planned:'Geplant','needs-review':'Prüfen',unavailable:'Nicht verfügbar'}
        };
        var evidenceLinks={zh:'查看证据',en:'View evidence',ja:'証拠を見る',es:'Ver evidencia',fr:'Voir la preuve',de:'Nachweis ansehen'};
        var fallbackStatus={
          zh:{title:'审计状态 JSON 不可用',copy:'公开报告页已加载，但暂时无法读取 /audit/status.json。'},
          en:{title:'Audit status JSON unavailable',copy:'The public report page loaded, but /audit/status.json could not be read.'}
        };
        var programCopy={
          'source-release-evidence':{zh:{category:'公开复现证据',name:'源码发布与 IPFS 证据',evidence:'核心公平源码包、发布清单、SHA256 与 IPFS CID 已公开，可独立复验。'},en:{category:'Reproducible evidence',name:'Source release and IPFS evidence',evidence:'The core fairness source package, release manifest, SHA256, and IPFS CID are public for independent verification.'}},
          'transcript-verifier':{zh:{category:'玩家可复验公平性',name:'牌局记录本地复验器',evidence:'每局完成后都可以下载 transcript，并在本地重放复验。'},en:{category:'Player-verifiable fairness',name:'Local transcript verifier',evidence:'After each hand you can download the transcript and replay-verify it locally.'}}
        };
        var payload=null, failed=false;
        function activeLanguage(){
          try{var s=String(localStorage.getItem('fairpoker:language')||'').toLowerCase().split('-')[0];if(languages.indexOf(s)>=0)return s;}catch(e){}
          return 'zh';
        }
        function textFor(map,l){return (map&&(map[l]||map.en||map.zh))||''}
        function render(){
          var l=activeLanguage(), root=document.getElementById('programs');
          if(!root)return; root.innerHTML='';
          if(failed){var f=fallbackStatus[l]||fallbackStatus.en;root.innerHTML='<article class="program" data-status="unavailable"><span class="status">'+((labels[l]||labels.en).unavailable)+'</span><strong>'+f.title+'</strong><p>'+f.copy+'</p></article>';return;}
          if(!payload){root.innerHTML='<article class="program"><span class="status">…</span><strong>'+(l==='zh'?'正在读取证据状态…':'Loading assurance status…')+'</strong><p>/audit/status.json</p></article>';return;}
          payload.programs.forEach(function(program){
            var loc=(programCopy[program.id]&&programCopy[program.id][l])||(programCopy[program.id]&&programCopy[program.id].en)||program;
            var item=document.createElement('article');
            item.className='program'; item.dataset.status=program.status; item.dataset.programId=program.id;
            var link=program.reportUrl?'<a href="'+program.reportUrl+'" target="_blank" rel="noreferrer">'+textFor(evidenceLinks,l)+'</a>':'';
            item.innerHTML='<span class="status">'+(((labels[l]||labels.en)[program.status])||program.status)+'</span><span>'+loc.category+'</span><strong>'+loc.name+'</strong><p>'+loc.evidence+'</p><small>'+program.providers.join(' · ')+'</small>'+link;
            root.appendChild(item);
          });
        }
        fetch('/audit/status.json').then(function(r){return r.json()}).then(function(s){payload=s;render();}).catch(function(){failed=true;render();});
        document.addEventListener('fairpoker:languagechange', render);
      })();
    </script>
  </body>
</html>
